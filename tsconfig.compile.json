{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "ignoreDeprecations": "6.0"
  },
  "include": ["extensions/**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "npm-packages", "dist"]
}
