{
  "name": "@vtstech/pi-coding-agent-extensions",
  "version": "1.3.1",
  "description": "Pi Coding Agent extensions: security, ReAct fallback, model benchmark, Ollama sync, diagnostics, system monitor, long-term memory, and Matrix theme",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extensions",
    "ollama",
    "model-test",
    "status-bar",
    "security",
    "react-fallback",
    "long-term-memory"
  ],
  "license": "MIT",
  "author": "VTSTech",
  "homepage": "https://www.vts-tech.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/VTSTech/pi-coding-agent"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "build": "npm run build:ltm",
    "build:ltm": "cd individual-packages/pi-long-term-memory && npx esbuild ltm.ts --bundle --outfile=../../dist/extensions/ltm.js --format=cjs --platform=node",
    "publish": "npm run build && npm publish",
    "publish:long-term-memory": "cd individual-packages/pi-long-term-memory && npm publish"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "themes": [
      "./themes"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
